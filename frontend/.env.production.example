# Production environment for the Vite build.
#
# Copy this to `.env.production` and replace the placeholder with your
# actual Azure App Service hostname (no trailing slash). The /api suffix
# matters — the FastAPI backend serves routes under that prefix.
#
#   cp .env.production.example .env.production
#   # edit .env.production with the real hostname
#   npm run build
#
# Vite picks up `.env.production` automatically when NODE_ENV=production
# (which is what `npm run build` sets). The resulting `dist/` folder gets
# uploaded to Azure Static Web Apps.
#
# Alternative: skip the file and pass at build time:
#   VITE_API_BASE=https://my-backend.azurewebsites.net/api npm run build

VITE_API_BASE=https://<your-backend-app-name>.azurewebsites.net/api
